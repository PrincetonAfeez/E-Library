#!/usr/bin/env sh
# Full CI pipeline gate on every push (the same steps as .github/workflows/ci.yml):
# ruff -> bandit -> pip-audit -> migration drift -> system check -> pytest.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Requires DATABASE_URL + CACHE_URL reachable (e.g. `docker compose up -d db redis`).
# Emergency bypass (use sparingly): git push --no-verify
set -e

exec sh scripts/ci.sh
