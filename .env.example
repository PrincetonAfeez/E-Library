# Set DEBUG=True only for local development.
DEBUG=False
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DATABASE_URL=postgres://elibrary:elibrary@db:5432/elibrary
CACHE_URL=redis://redis:6379/0
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=library@example.test
SENTRY_DSN=
CORS_ALLOWED_ORIGINS=http://localhost:8000
# Hosted SaaS posture (deny features without a serviceable subscription)
SAAS_MODE=False
# Optional dedicated key for Fernet at-rest encryption (defaults to SECRET_KEY)
FIELD_ENCRYPTION_KEY=
# Reject legacy plaintext secret values in non-development environments.
DISALLOW_PLAINTEXT_SECRETS=True
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional S3 media (django-storages); leave blank for local FileSystemStorage
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AI_PROVIDER=local

